<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.missaccesorios.app">

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="Miss Accesorios"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <activity android:name=".activities.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

        <activity android:name=".activities.ProveedorActivity" android:exported="false"/>
        <activity android:name=".activities.NuevaVentaActivity" android:exported="false"/>
        <activity android:name=".activities.HistorialVentasActivity" android:exported="false"/>
        <activity android:name=".activities.CorteCajaActivity" android:exported="false"/>
        <activity android:name=".activities.DetalleVentaActivity" android:exported="false"/>
        <activity android:name=".activities.HistorialCortesActivity" android:exported="false"/>
        <activity android:name=".activities.DetalleCorteActivity" android:exported="false"/>
        <activity android:name=".activities.ReportesActivity" android:exported="false"/>
        <activity android:name=".activities.HistorialPagosProveedorActivity" android:exported="false"/>
        <activity android:name=".activities.PagosProveedorActivity" android:exported="false"/>

    </application>
</manifest>